#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

PREFIX=${PREFIX:-/usr/local}
WORKDIR=${WORKDIR:-"${HOME}/src/chimera-xdm-afterstep"}
JOBS=${JOBS:-$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)}

AFTERSTEP_JOBS=${AFTERSTEP_JOBS:-1}
CLEAN_AFTERSTEP=${CLEAN_AFTERSTEP:-1}

START_XDM=${START_XDM:-0}
TRACE=${TRACE:-0}
DISPLAY_MANAGER=${DISPLAY_MANAGER:-xdm}

APK_TIMEOUT=${APK_TIMEOUT:-240}
APK_NET_TIMEOUT=${APK_NET_TIMEOUT:-30}
GIT_TIMEOUT=${GIT_TIMEOUT:-300}
XDM_CPP_WRAPPER=${XDM_CPP_WRAPPER:-"${WORKDIR}/xdm-cpp-wrapper"}
XDM_TOOLKIT_FALLBACK=${XDM_TOOLKIT_FALLBACK:-1}
LIBXAW_REPO=${LIBXAW_REPO:-https://gitlab.freedesktop.org/xorg/lib/libXaw.git}
LIBXAW_REPO_FALLBACK=${LIBXAW_REPO_FALLBACK:-https://github.com/freedesktop-unofficial-mirror/xorg__lib__libXaw.git}
BUILD_LIBXAW_IF_MISSING=${BUILD_LIBXAW_IF_MISSING:-1}
XDM_SKIP_CHOOSER_IF_NO_XAW=${XDM_SKIP_CHOOSER_IF_NO_XAW:-1}
DINIT_SERVICE_DIR=${DINIT_SERVICE_DIR:-/etc/dinit.d}
DINIT_BOOT_DIR=${DINIT_BOOT_DIR:-/etc/dinit.d/boot.d}
DINIT_XDM_SERVICE=${DINIT_XDM_SERVICE:-xdm}
DINIT_ESXDM_SERVICE=${DINIT_ESXDM_SERVICE:-esxdm}
DINIT_START_XDM_AFTER_ENABLE=${DINIT_START_XDM_AFTER_ENABLE:-0}
ESXDM_PAM_DIR=${ESXDM_PAM_DIR:-/usr/lib/pam.d}

AFTERSTEP_REPO=${AFTERSTEP_REPO:-https://github.com/afterstep/afterstep.git}
XDM_REPO=${XDM_REPO:-https://gitlab.freedesktop.org/xorg/app/xdm.git}
XDM_REPO_FALLBACK=${XDM_REPO_FALLBACK:-https://github.com/freedesktop-unofficial-mirror/xorg__app__xdm.git}
ESXDM_REPO=${ESXDM_REPO:-https://github.com/raadsilva1/chimera-esdxm.git}
ESXDM_REPO_FALLBACK=${ESXDM_REPO_FALLBACK:-}

USERNAME=
KEYBOARD_LAYOUT=
LOGFILE=

declare -a AS_ROOT=()

timestamp(){ date '+%Y-%m-%d %H:%M:%S'; }
log(){ printf '[%s] [+] %s\n' "$(timestamp)" "$*"; }
warn(){ printf '[%s] [!] %s\n' "$(timestamp)" "$*" >&2; }
die(){ printf '[%s] [x] %s\n' "$(timestamp)" "$*" >&2; exit 1; }

trap 'rc=$?; warn "failed with rc=$rc at line ${LINENO}: ${BASH_COMMAND}"; exit "$rc"' ERR

usage(){
  cat <<EOF
Usage: $0 [-u username] [-y keyboard_layout] [-o xdm|esxdm] [-v] [-h]

Options:
  -u <username>          Configure AfterStep .xsession for an existing user
  -y <keyboard layout>   Configure Xorg keyboard layout, e.g. us, br, de, br,us
  -o <xdm|esxdm>         Display manager to build/configure; default: xdm
  -v                     Enable shell xtrace
  -h                     Show this help

Environment:
  PREFIX=/usr/local      Install prefix
  WORKDIR=~/src/...      Build directory
  JOBS=N                 Parallel build jobs for xdm and other builds
  AFTERSTEP_JOBS=1       Parallel jobs for AfterStep; default is 1 for reliability
  CLEAN_AFTERSTEP=1      Clean partial AfterStep build before rebuilding
  START_XDM=1            Start selected display manager immediately after install
  DISPLAY_MANAGER=xdm     Default display manager; xdm or esxdm
  APK_TIMEOUT=240        Outer timeout in seconds for each apk operation
  APK_NET_TIMEOUT=30     apk network timeout in seconds
  GIT_TIMEOUT=300        Timeout in seconds for git clone/fetch/pull
  XDM_CPP_WRAPPER=...    Override path for xdm cpp wrapper
  XDM_TOOLKIT_FALLBACK=1 Enable xdm Xaw toolkit fallback when xaw7.pc is absent
  BUILD_LIBXAW_IF_MISSING=1 Build libXaw from source if Xaw headers are absent
  XDM_SKIP_CHOOSER_IF_NO_XAW=1 Skip xdm chooser if Xaw headers still cannot be provided
  DINIT_SERVICE_DIR=/etc/dinit.d Directory for local system dinit service files
  DINIT_BOOT_DIR=/etc/dinit.d/boot.d Directory for enabled boot symlinks
  DINIT_XDM_SERVICE=xdm Service name to install/enable for xdm
  DINIT_ESXDM_SERVICE=esxdm Service name to install/enable for esxdm
  ESXDM_PAM_DIR=/usr/lib/pam.d PAM config directory for esxdm
  ESXDM_REPO=...        Override esxdm source repository
  DINIT_START_XDM_AFTER_ENABLE=1 Start xdm after enabling, independent of START_XDM
  LIBXAW_REPO=...       Override libXaw source repository
  TRACE=1                Same as -v
EOF
}

parse_args(){
  while getopts ":u:y:o:vh" opt; do
    case "$opt" in
      u) USERNAME=$OPTARG ;;
      y) KEYBOARD_LAYOUT=$OPTARG ;;
      o) DISPLAY_MANAGER=$OPTARG ;;
      v) TRACE=1 ;;
      h) usage; exit 0 ;;
      :) die "option -$OPTARG requires an argument" ;;
      \?) die "unknown option: -$OPTARG" ;;
    esac
  done

  if [ -n "$USERNAME" ] && ! getent passwd "$USERNAME" >/dev/null 2>&1; then
    die "user does not exist: $USERNAME"
  fi

  if [ -n "$KEYBOARD_LAYOUT" ]; then
    case "$KEYBOARD_LAYOUT" in
      *[!A-Za-z0-9_,.-]*)
        die "invalid keyboard layout: $KEYBOARD_LAYOUT"
        ;;
    esac
  fi

  case "$DISPLAY_MANAGER" in
    xdm|esxdm) ;;
    *) die "invalid display manager for -o: $DISPLAY_MANAGER (expected xdm or esxdm)" ;;
  esac
}

init_logging(){
  mkdir -p "$WORKDIR"
  LOGFILE=${LOGFILE:-"${WORKDIR}/install-$(date '+%Y%m%d-%H%M%S').log"}

  if command -v tee >/dev/null 2>&1; then
    exec > >(tee -a "$LOGFILE") 2>&1
  fi

  log "log file: $LOGFILE"

  if [ "$TRACE" = 1 ]; then
    PS4='+ ${BASH_SOURCE##*/}:${LINENO}: '
    set -x
  fi
}

quote_cmd(){
  local arg
  for arg in "$@"; do
    printf '%q ' "$arg"
  done
}

stage(){
  printf '\n'
  log "==== $* ===="
}

detect_os(){
  stage "detecting OS"

  if [ -r /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    log "os-release ID=${ID:-unknown} VERSION_ID=${VERSION_ID:-unknown}"
    [ "${ID:-}" = chimera ] || warn "this does not look like Chimera Linux: ID=${ID:-unknown}"
  else
    warn "/etc/os-release not found; continuing anyway"
  fi
}

setup_privilege(){
  stage "checking privilege method"

  if [ "$(id -u)" -eq 0 ]; then
    AS_ROOT=()
    log "running as root"
  elif command -v doas >/dev/null 2>&1; then
    AS_ROOT=(doas)
    log "using doas"
  elif command -v sudo >/dev/null 2>&1; then
    AS_ROOT=(sudo)
    log "using sudo"
  else
    die "run as root, or install/configure doas or sudo"
  fi

  root true || die "privilege check failed"
}

root(){
  if [ "${#AS_ROOT[@]}" -eq 0 ]; then
    "$@"
  else
    "${AS_ROOT[@]}" "$@"
  fi
}

run_timeout(){
  local seconds=$1
  shift

  if command -v timeout >/dev/null 2>&1; then
    timeout "$seconds" "$@"
  else
    warn "timeout command not found; running without timeout: $(quote_cmd "$@")"
    "$@"
  fi
}

run_cmd(){
  log "run: $(quote_cmd "$@")"
  "$@"
}

run_timed(){
  local seconds=$1
  shift
  log "run timeout=${seconds}s: $(quote_cmd "$@")"
  run_timeout "$seconds" "$@"
}

run_root_cmd(){
  log "root: $(quote_cmd "$@")"
  root "$@"
}

run_root_timed(){
  local seconds=$1
  shift

  if command -v timeout >/dev/null 2>&1; then
    if [ "${#AS_ROOT[@]}" -eq 0 ]; then
      log "root timeout=${seconds}s: $(quote_cmd "$@")"
      timeout "$seconds" "$@"
    else
      log "root timeout=${seconds}s: $(quote_cmd "${AS_ROOT[@]}" "$@")"
      timeout "$seconds" "${AS_ROOT[@]}" "$@"
    fi
  else
    warn "timeout command not found; running privileged command without timeout"
    run_root_cmd "$@"
  fi
}

apk_cmd(){
  run_root_timed "$APK_TIMEOUT" \
    apk \
      --interactive=no \
      --progress=no \
      --timeout="$APK_NET_TIMEOUT" \
      "$@"
}

print_apk_repo_state(){
  stage "apk repository state"

  local found=0
  local path

  for path in \
    /etc/apk/repositories \
    /etc/apk/repositories.d/*.list \
    /usr/lib/apk/repositories \
    /usr/lib/apk/repositories.d/*.list
  do
    [ -e "$path" ] || continue
    found=1
    log "repo/config file: $path"
    sed 's/^/    /' "$path" || true
  done

  if [ "$found" = 0 ]; then
    warn "no visible apk repository files found in /etc/apk or /usr/lib/apk"
    warn "continuing anyway; apk update will decide whether repositories are configured"
  fi

  if command -v apk >/dev/null 2>&1; then
    apk info 2>/dev/null | grep '^chimera-repo' || warn "no installed chimera-repo packages shown by apk info"
  fi
}

apk_update_indexes(){
  stage "refreshing apk indexes"

  print_apk_repo_state

  log "apk timeout=${APK_TIMEOUT}s net-timeout=${APK_NET_TIMEOUT}s"

  if ! apk_cmd update; then
    cat >&2 <<EOF
[x] apk update failed or timed out.

Try manually:
    apk --interactive=no --progress=no --timeout=$APK_NET_TIMEOUT update

Inspect:
    apk info | grep '^chimera-repo'
    find /etc/apk /usr/lib/apk -maxdepth 3 -type f -print
    cat /etc/apk/config 2>/dev/null
    cat /usr/lib/apk/config 2>/dev/null

To set a mirror override:
    mkdir -p /etc/apk/repositories.d
    echo 'set CHIMERA_REPO_URL=https://repo.chimera-linux.org' > /etc/apk/repositories.d/00-custom.list

Log:
    $LOGFILE
EOF
    exit 1
  fi
}

apk_add_list(){
  local mode=$1
  local label=$2
  shift 2

  local -a pkgs=("$@")
  [ "${#pkgs[@]}" -gt 0 ] || return 0

  stage "apk add ${mode}: ${label}"
  log "package set: ${pkgs[*]}"

  if apk_cmd add "${pkgs[@]}"; then
    log "installed package set: $label"
    return 0
  fi

  warn "batch install failed for: $label"
  warn "falling back to individual packages"

  local rc=0
  local pkg

  for pkg in "${pkgs[@]}"; do
    log "trying package: $pkg"

    if apk_cmd add "$pkg"; then
      log "installed: $pkg"
    else
      if [ "$mode" = required ]; then
        warn "required package failed: $pkg"
        rc=1
      else
        warn "optional package skipped: $pkg"
      fi
    fi
  done

  if [ "$mode" = required ] && [ "$rc" -ne 0 ]; then
    die "one or more required packages failed for group: $label"
  fi
}

apk_add_any_required(){
  local label=$1
  shift

  local pkg

  stage "apk add required alternative: $label"
  log "candidates: $*"

  for pkg in "$@"; do
    log "trying alternative: $pkg"

    if apk_cmd add "$pkg"; then
      log "installed alternative for $label: $pkg"
      return 0
    fi

    warn "failed alternative: $pkg"
  done

  die "no candidate worked for required dependency: $label"
}

apk_add_any_optional(){
  local label=$1
  shift

  local pkg

  stage "apk add optional alternative: $label"
  log "candidates: $*"

  for pkg in "$@"; do
    log "trying optional alternative: $pkg"

    if apk_cmd add "$pkg"; then
      log "installed optional alternative for $label: $pkg"
      return 0
    fi

    warn "failed optional alternative: $pkg"
  done

  warn "no candidate worked for optional dependency: $label"
}

apk_add_pc_optional(){
  local label=$1
  shift

  local -a pkgs=()
  local pc

  for pc in "$@"; do
    pkgs+=("pc:$pc")
  done

  apk_add_list optional "$label" "${pkgs[@]}"
}

pkgconf_cmd(){
  if command -v pkg-config >/dev/null 2>&1; then
    command -v pkg-config
  elif command -v pkgconf >/dev/null 2>&1; then
    command -v pkgconf
  else
    return 1
  fi
}

show_pkg_config_status(){
  stage "pkg-config status"

  local pc cmd
  cmd=$(pkgconf_cmd) || {
    warn "pkg-config/pkgconf not available yet"
    return 0
  }

  for pc in "$@"; do
    if "$cmd" --exists "$pc" >/dev/null 2>&1; then
      log "pc:$pc -> $("$cmd" --modversion "$pc" 2>/dev/null || printf found)"
    else
      warn "pc:$pc not found"
    fi
  done
}

require_command(){
  local cmd=$1
  command -v "$cmd" >/dev/null 2>&1 || die "required command missing after dependency install: $cmd"
  log "found command: $cmd -> $(command -v "$cmd")"
}

